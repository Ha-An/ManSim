{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mansim.local/replay-log.schema.json",
  "type": "object",
  "required": ["schema_version", "metadata", "events"],
  "properties": {
    "schema_version": { "const": "1.0" },
    "metadata": {
      "type": "object",
      "required": ["run_id", "domain", "total_duration", "time_unit"],
      "properties": {
        "run_id": { "type": "string", "minLength": 1 },
        "title": { "type": "string" },
        "domain": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "created_at": { "type": "string" },
        "total_duration": { "type": "number", "minimum": 0 },
        "time_unit": { "enum": ["seconds", "minutes"] }
      },
      "additionalProperties": true
    },
    "layout": { "type": "object" },
    "initial_state": { "type": "object" },
    "checkpoints": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["checkpoint_id", "event_cursor", "timestamp", "snapshot"],
        "properties": {
          "checkpoint_id": { "type": "string", "minLength": 1 },
          "event_cursor": { "type": "integer", "minimum": 0 },
          "timestamp": { "type": "number", "minimum": 0 },
          "snapshot": { "type": "object" }
        },
        "additionalProperties": true
      }
    },
    "events": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["event_id", "sequence_index", "timestamp", "event_type", "entity_refs", "payload"],
        "properties": {
          "event_id": { "type": "string", "minLength": 1 },
          "sequence_index": { "type": "integer", "minimum": 0 },
          "timestamp": { "type": "number", "minimum": 0 },
          "event_type": { "type": "string", "minLength": 1 },
          "entity_refs": {
            "type": "object",
            "properties": {
              "primary": { "type": "string" },
              "related": { "type": "array", "items": { "type": "string" } },
              "source": { "type": "string" },
              "target": { "type": "string" }
            },
            "additionalProperties": true
          },
          "durative": {
            "type": "object",
            "properties": {
              "started_at": { "type": "number", "minimum": 0 },
              "ended_at": { "type": "number", "minimum": 0 },
              "expected_duration": { "type": "number", "minimum": 0 }
            },
            "additionalProperties": true
          },
          "payload": { "type": "object" }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": false
}
